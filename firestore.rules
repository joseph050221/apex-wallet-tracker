rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Verify if the authenticated user is the whitelisted developer
    function isDeveloper() {
      return request.auth != null && request.auth.token.email == 'josephzhangce0221@gmail.com';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isDeveloper();

      match /cards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isDeveloper();
      }

      match /transactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isDeveloper();
      }
    }
  }
}
